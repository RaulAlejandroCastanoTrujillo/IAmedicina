# ============================================================
# Health AI / MediScribe — Variables de entorno
# Copia este archivo a ".env" y completa los valores.
#   cp .env.example .env
# ============================================================

# Obligatorio: tu API key de OpenAI (platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Opcional: URL pública que usará la app para llamar al webhook de n8n.
# Cámbiala solo si accedes desde otra máquina de tu red o un dominio.
N8N_PUBLIC_URL=http://localhost:5678

# Opcional: host/URL interna que usa n8n para construir sus propias URLs
N8N_HOST=localhost
WEBHOOK_URL=http://localhost:5678/

# Opcional pero recomendado: clave fija para cifrar credenciales en n8n.
# Si no la defines, se usa una de desarrollo (cámbiala para producción).
N8N_ENCRYPTION_KEY=cambia-esta-clave-por-una-segura-y-larga
